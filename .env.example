GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Edge-TTS voice — Andrew is engaging and clear, good for game-show format
# Full list: run `edge-tts --list-voices` to browse options
EDGE_TTS_VOICE=en-US-AndrewNeural

# Free Pexels API key — sign up at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# YouTube OAuth — see README for setup instructions
YT_CLIENT_SECRETS_FILE=client_secret.json
YT_TOKEN_FILE=yt_token.json

# Video content settings
ROUNDS_PER_VIDEO=3
VIDEOS_PER_RUN=1

# Set to True to pause before upload and manually review the rendered video
MANUAL_REVIEW_GATE=False

# Upload scheduling — 16:00 UTC = 9:00 AM PST / 12:00 PM EST / 9:30 PM IST
# Offset from other channels to avoid CPU/network contention
PUBLISH_HOUR_UTC=16

# Timer suspense duration in seconds (3.0 = 3 ticks)
TIMER_SECONDS=3.0

# Percentage reveal range — winning side always in this range
PERCENT_SPLIT_MIN=55
PERCENT_SPLIT_MAX=82

# Path to Poppins-Bold.ttf (see README for install instructions)
FONT_PATH=~/.fonts/Poppins-Bold.ttf
